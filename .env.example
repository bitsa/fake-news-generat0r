DATABASE_URL=postgresql+asyncpg://fakenews:fakenews@postgres:5432/fakenews  # Async SQLAlchemy connection string. Must use asyncpg driver.
REDIS_URL=redis://redis:6379/0  # Redis connection string. Used by the ARQ broker only (see context.md "Redis is ARQ Broker Only").
OPENAI_API_KEY=sk-REPLACE_ME  # OpenAI API key. Never log this value. Replace before running.
OPENAI_MODEL_TRANSFORM=gpt-4o-mini  # Model used by the transformation job.
OPENAI_MODEL_CHAT=gpt-4o-mini  # Model used by the chat endpoint.
OPENAI_TEMPERATURE_TRANSFORM=0.9  # Temperature for transformation (higher = more creative).
OPENAI_TEMPERATURE_CHAT=0.7  # Temperature for chat responses.
OPENAI_REQUEST_TIMEOUT_SECONDS=30  # Per-request timeout for the OpenAI client (seconds).
SCRAPE_MAX_PER_SOURCE=10  # Max feed entries persisted per source per scrape (1.3).
SCRAPE_INTERVAL_MINUTES=60  # ARQ cron interval for scheduled scraping (Iteration 3). 0 disables.
OPENAI_MOCK_MODE=true  # If true, uses mock OpenAI responses for testing without API calls. Set to false to use real API.
CHAT_LLM_MOCK=true  # If true, chat path uses the deterministic mock generator (no OpenAI call).
CHAT_HISTORY_WINDOW=10  # Max prior chat_messages rows injected into each prompt (oldest-first).
CHAT_MAX_OUTPUT_TOKENS=512  # Per-request `max_tokens` cap for the chat completion.
